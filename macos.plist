<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>fr.frenchbytes.clipmap</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Applications/clipmap.app/Contents/MacOS/clipmap</string>
    </array>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/clipmap.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/clipmap.err</string>
</dict>
</plist>
